<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Assessment List View -->
    <record id="itx_revival_assessment_view_list" model="ir.ui.view">
        <field name="name">itx.revival.assessment.view.list</field>
        <field name="model">itx.revival.assessment</field>
        <field name="arch" type="xml">
            <list string="Assessments" decoration-info="state == 'draft'"
                  decoration-warning="state == 'assessed'"
                  decoration-success="state == 'decided'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="assessment_date"/>
                <field name="spec_id"/>
                <field name="brand_id" optional="hide"/>
                <field name="model_id" optional="hide"/>
                <field name="body_type_id"/>
                <field name="assessor_id" optional="show"/>
                <field name="asking_price" optional="show"/>
                <field name="target_price"/>
                <field name="expected_revenue"/>
                <field name="expected_roi" widget="percentage"/>
                <field name="decision" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'assessed'"
                       decoration-success="state in ('decided', 'acquired')"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Assessment Form View -->
    <record id="itx_revival_assessment_view_form" model="ir.ui.view">
        <field name="name">itx.revival.assessment.view.form</field>
        <field name="model">itx.revival.assessment</field>
        <field name="arch" type="xml">
            <form string="Assessment">
                <header>
                    <button name="action_generate_lines" type="object"
                            string="Generate Lines" class="oe_highlight"
                            invisible="state != 'draft' or line_count > 0"/>
                    <button name="action_assessed" type="object"
                            string="Mark as Assessed" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_decide" type="object"
                            string="Confirm Decision" class="oe_highlight"
                            invisible="state != 'assessed'"/>
                    <button name="action_create_acquired" type="object"
                            string="Create Acquired" class="oe_highlight"
                            invisible="state != 'decided' or decision == 'not_buy'"/>
                    <button name="action_print_checklist" type="object"
                            string="Print Checklist"
                            invisible="state == 'draft'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('acquired', 'cancelled')"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,assessed,decided,acquired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list"
                                type="object" name="action_view_lines"
                                invisible="line_count == 0">
                            <field name="line_count" widget="statinfo" string="Parts"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Vehicle Information">
                            <field name="spec_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="body_type_id" readonly="1"/>
                            <field name="brand_id" readonly="1"/>
                            <field name="model_id" readonly="1"/>
                            <field name="generation_id" readonly="1"/>
                        </group>
                        <group string="Vehicle Details">
                            <field name="vehicle_year"/>
                            <field name="vehicle_color"/>
                            <field name="vehicle_mileage"/>
                            <field name="vehicle_vin"/>
                            <field name="location"/>
                        </group>
                    </group>
                    <group>
                        <group string="Assessment">
                            <field name="assessor_id"/>
                            <field name="assessment_date"/>
                        </group>
                        <group string="Pricing">
                            <field name="asking_price"/>
                            <field name="target_price"/>
                            <field name="expected_revenue" readonly="1"/>
                            <field name="expected_profit" readonly="1"/>
                            <field name="expected_roi" readonly="1" widget="percentage"/>
                        </group>
                    </group>
                    <group string="Decision" invisible="state == 'draft'">
                        <group>
                            <field name="decision"
                                   readonly="state not in ('assessed', 'decided')"/>
                            <field name="decision_date" readonly="1"/>
                            <field name="decision_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="decision_note"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assessment Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="part_name_id"/>
                                    <field name="part_category_id" readonly="1"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="expected_price"/>
                                    <field name="cost_weight"/>
                                    <field name="allocated_cost" readonly="1"/>
                                    <field name="is_found"/>
                                    <field name="actual_condition"/>
                                    <field name="field_note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Assessment Search View -->
    <record id="itx_revival_assessment_view_search" model="ir.ui.view">
        <field name="name">itx.revival.assessment.view.search</field>
        <field name="model">itx.revival.assessment</field>
        <field name="arch" type="xml">
            <search string="Search Assessments">
                <field name="name"/>
                <field name="spec_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="body_type_id"/>
                <field name="assessor_id"/>
                <field name="vehicle_vin"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Assessed" name="filter_assessed"
                        domain="[('state', '=', 'assessed')]"/>
                <filter string="Decided" name="filter_decided"
                        domain="[('state', '=', 'decided')]"/>
                <filter string="Acquired" name="filter_acquired"
                        domain="[('state', '=', 'acquired')]"/>
                <separator/>
                <filter string="To Buy" name="filter_to_buy"
                        domain="[('decision', 'in', ['sell_whole', 'dismantle'])]"/>
                <filter string="Not Buy" name="filter_not_buy"
                        domain="[('decision', '=', 'not_buy')]"/>
                <separator/>
                <filter string="Archived" name="filter_archived"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter string="State" name="groupby_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Decision" name="groupby_decision" domain="[]" context="{'group_by': 'decision'}"/>
                    <filter string="Brand" name="groupby_brand" domain="[]" context="{'group_by': 'brand_id'}"/>
                    <filter string="Body Type" name="groupby_body_type" domain="[]" context="{'group_by': 'body_type_id'}"/>
                    <filter string="Assessor" name="groupby_assessor" domain="[]" context="{'group_by': 'assessor_id'}"/>
                    <filter string="Assessment Date" name="groupby_date" domain="[]" context="{'group_by': 'assessment_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Assessment Action -->
    <record id="itx_revival_assessment_action" model="ir.actions.act_window">
        <field name="name">Assessments</field>
        <field name="res_model">itx.revival.assessment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first assessment
            </p>
            <p>
                สร้างแบบประเมินซากรถเพื่อประเมินความคุ้มค่าก่อนซื้อ
            </p>
        </field>
    </record>

</odoo>
