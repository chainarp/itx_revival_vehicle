<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Assessment List View -->
    <record id="itx_revival_assessment_view_list" model="ir.ui.view">
        <field name="name">itx.revival.assessment.view.list</field>
        <field name="model">itx.revival.assessment</field>
        <field name="arch" type="xml">
            <list string="Assessments"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'offering'"
                  decoration-success="state in ('assessed', 'sold', 'dismantle')"
                  decoration-muted="state == 'returned'">
                <field name="name"/>
                <field name="assessment_date"/>
                <field name="ecf_claim_number" optional="show"/>
                <field name="plate_number" optional="show"/>
                <field name="insurance_partner_id" optional="hide"/>
                <field name="spec_id"/>
                <field name="brand_id" optional="hide"/>
                <field name="model_id" optional="hide"/>
                <field name="body_type_id"/>
                <field name="assessor_id" optional="show"/>
                <field name="insurance_value" optional="hide"/>
                <field name="is_parking_reported" optional="hide"/>
                <field name="suggested_price" optional="show"/>
                <field name="target_price" optional="show"/>
                <field name="expected_revenue" optional="hide"/>
                <field name="expected_roi" widget="percentage" optional="hide"/>
                <field name="offering_deadline" optional="hide"/>
                <field name="decision" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'offering'"
                       decoration-success="state in ('assessed', 'sold', 'dismantle')"
                       decoration-danger="state == 'returned'"/>
            </list>
        </field>
    </record>

    <!-- Assessment Form View -->
    <record id="itx_revival_assessment_view_form" model="ir.ui.view">
        <field name="name">itx.revival.assessment.view.form</field>
        <field name="model">itx.revival.assessment</field>
        <field name="arch" type="xml">
            <form string="Assessment">
                <header>
                    <!-- === draft: ทำงานประเมิน === -->
                    <button name="action_generate_lines" type="object"
                            string="Generate Lines" class="oe_highlight"
                            invisible="state != 'draft' or line_count > 0"/>
                    <button name="action_open_bom" type="object"
                            string="Edit BOM"
                            invisible="state != 'draft' or not bom_id"/>
                    <button name="action_sync_from_bom" type="object"
                            string="Sync from BOM"
                            invisible="state != 'draft' or not bom_id"
                            confirm="ข้อมูล field survey จะถูกล้าง ยืนยัน?"/>
                    <button name="action_print_checklist" type="object"
                            string="Print Checklist"
                            invisible="state != 'draft' or line_count == 0"/>
                    <button name="action_assess" type="object"
                            string="Complete Assessment" class="oe_highlight"
                            invisible="state != 'draft' or line_count == 0"/>

                    <!-- === assessed: ตัดสินใจ 3 ทาง === -->
                    <button name="action_return" type="object"
                            string="Return (ไม่ซื้อ)"
                            invisible="state != 'assessed'"
                            confirm="ยืนยันคืนรถให้ประกัน?"/>
                    <button name="action_decide_dismantle" type="object"
                            string="Dismantle (ซื้อแยก)" class="oe_highlight"
                            invisible="state != 'assessed'"/>
                    <button name="action_offer" type="object"
                            string="Offer (ขายยกคัน)" class="oe_highlight"
                            invisible="state != 'assessed'"/>

                    <!-- === offering: wait state === -->
                    <button name="action_sold" type="object"
                            string="Sold (ลูกค้าจ่ายครบ)" class="oe_highlight"
                            invisible="state != 'offering'"/>
                    <button name="action_offering_dismantle" type="object"
                            string="Change to Dismantle (เปลี่ยนใจแยก)"
                            invisible="state != 'offering'"/>
                    <button name="action_offering_return" type="object"
                            string="Return (คืน/หมดเวลา)"
                            invisible="state != 'offering'"
                            confirm="ยืนยันคืนรถให้ประกัน?"/>

                    <!-- === sold / dismantle: สร้าง Acquired === -->
                    <button name="action_create_acquired" type="object"
                            string="Create Acquired Vehicle" class="oe_highlight"
                            invisible="state not in ('sold', 'dismantle') or acquired_id"/>

                    <!-- === returned: reset === -->
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'returned'"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,assessed,offering,sold,dismantle"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list"
                                type="object" name="action_view_lines"
                                invisible="line_count == 0">
                            <field name="line_count" widget="statinfo" string="Parts"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-camera"
                                type="object" name="action_view_images"
                                invisible="image_count == 0">
                            <field name="image_count" widget="statinfo" string="Images"/>
                        </button>
                    </div>
                    <field name="image_main" widget="image" class="oe_avatar"
                           options="{'preview_image': 'image_main'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Row 1: Vehicle Info + Details -->
                    <group>
                        <group string="Vehicle Information">
                            <field name="spec_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="body_type_id" readonly="1"/>
                            <field name="brand_id" readonly="1"/>
                            <field name="model_id" readonly="1"/>
                            <field name="generation_id" readonly="1"/>
                        </group>
                        <group string="Vehicle Details">
                            <field name="vehicle_year"/>
                            <field name="vehicle_color"/>
                            <field name="vehicle_mileage"/>
                            <field name="vehicle_vin"/>
                            <label for="plate_number"/>
                            <div class="o_row">
                                <field name="plate_number" placeholder="เช่น กข-1234"/>
                                <field name="plate_province" placeholder="จังหวัด"/>
                            </div>
                            <field name="location"/>
                            <field name="overall_condition"/>
                            <field name="overall_condition_note"
                                   invisible="not overall_condition"/>
                        </group>
                    </group>

                    <!-- Row 2: Insurance + Assessment -->
                    <group>
                        <group string="Insurance Source">
                            <field name="insurance_partner_id"
                                   options="{'no_create': True}"/>
                            <field name="ecf_claim_number"/>
                            <field name="claim_date"/>
                            <field name="registration_book_status"/>
                            <field name="company_currency_id" invisible="1"/>
                        </group>
                        <group string="Assessment">
                            <field name="assessor_id"/>
                            <field name="assessment_date"/>
                            <field name="bom_id" readonly="1"
                                   invisible="not bom_id"/>
                        </group>
                    </group>

                    <!-- Row 3: Pricing + Expected ROI -->
                    <group>
                        <group string="Pricing (ราคาเสนอซื้อซาก)">
                            <field name="insurance_value"/>
                            <field name="is_parking_reported"/>
                            <field name="suggested_price" readonly="1"/>
                            <field name="asking_price"/>
                            <field name="target_price"/>
                        </group>
                        <group string="Expected ROI">
                            <field name="expected_revenue" readonly="1"/>
                            <field name="expected_profit" readonly="1"/>
                            <field name="expected_roi" readonly="1" widget="percentage"/>
                        </group>
                    </group>

                    <!-- Row 4: Decision (visible after assessed) -->
                    <group string="Decision"
                           invisible="state == 'draft'">
                        <group>
                            <field name="decision" readonly="1"/>
                            <field name="decision_date" readonly="1"/>
                            <field name="decision_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="decision_note"
                                   readonly="state not in ('assessed', 'offering')"/>
                        </group>
                    </group>

                    <!-- Row 5: Offering details (visible in offering/sold) -->
                    <group string="Offering (ขายยกคัน)"
                           invisible="state not in ('assessed', 'offering', 'sold')">
                        <group>
                            <field name="offering_deadline"
                                   readonly="state not in ('assessed', 'offering')"/>
                            <field name="offering_start_date" readonly="1"/>
                            <field name="is_offering_expired"
                                   invisible="state != 'offering'"/>
                        </group>
                        <group>
                            <field name="offering_customer_id"
                                   readonly="state not in ('offering',)"/>
                            <field name="offering_sale_price"
                                   readonly="state not in ('offering',)"/>
                        </group>
                    </group>

                    <!-- Link to Acquired -->
                    <group invisible="not acquired_id">
                        <group>
                            <field name="acquired_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- Notebook -->
                    <notebook>
                        <page string="Assessment Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="part_name_id"/>
                                    <field name="part_category_id" readonly="1"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="part_origin_id" readonly="1"/>
                                    <field name="part_condition_id" readonly="1"/>
                                    <field name="qty_expected"/>
                                    <field name="expected_price"/>
                                    <field name="cost_weight"/>
                                    <field name="allocated_cost" readonly="1"/>
                                    <field name="is_found"/>
                                    <field name="qty_found"/>
                                    <field name="actual_condition_id"/>
                                    <field name="field_note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Images" name="images">
                            <field name="image_ids">
                                <kanban>
                                    <templates>
                                        <t t-name="card">
                                            <div class="o_kanban_image">
                                                <field name="image" widget="image"/>
                                            </div>
                                            <div class="oe_kanban_details">
                                                <strong><field name="caption"/></strong>
                                                <div><field name="category"/></div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                                <form>
                                    <sheet>
                                        <field name="image" widget="image"/>
                                        <group>
                                            <field name="caption"/>
                                            <field name="category"/>
                                            <field name="sequence"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Assessment Search View -->
    <record id="itx_revival_assessment_view_search" model="ir.ui.view">
        <field name="name">itx.revival.assessment.view.search</field>
        <field name="model">itx.revival.assessment</field>
        <field name="arch" type="xml">
            <search string="Search Assessments">
                <field name="name"/>
                <field name="spec_id"/>
                <field name="brand_id"/>
                <field name="model_id"/>
                <field name="body_type_id"/>
                <field name="assessor_id"/>
                <field name="vehicle_vin"/>
                <field name="plate_number"/>
                <field name="ecf_claim_number"/>
                <field name="insurance_partner_id"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Assessed" name="filter_assessed"
                        domain="[('state', '=', 'assessed')]"/>
                <filter string="Offering" name="filter_offering"
                        domain="[('state', '=', 'offering')]"/>
                <filter string="Sold" name="filter_sold"
                        domain="[('state', '=', 'sold')]"/>
                <filter string="To Dismantle" name="filter_dismantle"
                        domain="[('state', '=', 'dismantle')]"/>
                <filter string="Returned" name="filter_returned"
                        domain="[('state', '=', 'returned')]"/>
                <separator/>
                <filter string="Active (ยังไม่ปิด)" name="filter_active_flow"
                        domain="[('state', 'not in', ['returned'])]"/>
                <filter string="Offering Expired" name="filter_expired"
                        domain="[('is_offering_expired', '=', True), ('state', '=', 'offering')]"/>
                <separator/>
                <filter string="Parking Reported (15%)" name="filter_parking_reported"
                        domain="[('is_parking_reported', '=', True)]"/>
                <filter string="Not Reported (25%)" name="filter_not_reported"
                        domain="[('is_parking_reported', '=', False)]"/>
                <separator/>
                <filter string="Archived" name="filter_archived"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter string="State" name="groupby_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Decision" name="groupby_decision" domain="[]" context="{'group_by': 'decision'}"/>
                    <filter string="Brand" name="groupby_brand" domain="[]" context="{'group_by': 'brand_id'}"/>
                    <filter string="Body Type" name="groupby_body_type" domain="[]" context="{'group_by': 'body_type_id'}"/>
                    <filter string="Assessor" name="groupby_assessor" domain="[]" context="{'group_by': 'assessor_id'}"/>
                    <filter string="Insurance Company" name="groupby_insurance" domain="[]" context="{'group_by': 'insurance_partner_id'}"/>
                    <filter string="Assessment Date" name="groupby_date" domain="[]" context="{'group_by': 'assessment_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Assessment Action -->
    <record id="itx_revival_assessment_action" model="ir.actions.act_window">
        <field name="name">Assessments</field>
        <field name="res_model">itx.revival.assessment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first assessment
            </p>
            <p>
                สร้างแบบประเมินซากรถเพื่อประเมินความคุ้มค่าก่อนซื้อ
            </p>
        </field>
    </record>

</odoo>
