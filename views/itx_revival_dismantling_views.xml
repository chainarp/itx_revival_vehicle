<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dismantling List View -->
    <record id="itx_revival_dismantling_view_list" model="ir.ui.view">
        <field name="name">itx.revival.dismantling.view.list</field>
        <field name="model">itx.revival.dismantling</field>
        <field name="arch" type="xml">
            <list string="Dismantling Orders"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'in_progress'"
                  decoration-success="state == 'done'">
                <field name="name"/>
                <field name="acquired_id"/>
                <field name="vin"/>
                <field name="spec_id"/>
                <field name="dismantling_date"/>
                <field name="technician_id" optional="show"/>
                <field name="line_count" string="Parts"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- Dismantling Form View -->
    <record id="itx_revival_dismantling_view_form" model="ir.ui.view">
        <field name="name">itx.revival.dismantling.view.form</field>
        <field name="model">itx.revival.dismantling</field>
        <field name="arch" type="xml">
            <form string="Dismantling Order">
                <header>
                    <button name="action_generate_lines" type="object"
                            string="Generate Lines" class="oe_highlight"
                            invisible="state != 'draft' or line_count > 0"/>
                    <button name="action_start" type="object"
                            string="Start Dismantling" class="oe_highlight"
                            invisible="state != 'draft' or line_count == 0"/>
                    <button name="action_done" type="object"
                            string="Confirm Done" class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_unbuild" type="object"
                                class="oe_stat_button" icon="fa-cogs"
                                invisible="not unbuild_id">
                            <span class="o_stat_text">Unbuild Order</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Source">
                            <field name="acquired_id" readonly="1"/>
                            <field name="assessment_id" readonly="1"/>
                            <field name="spec_id" readonly="1"/>
                            <field name="vin" readonly="1"/>
                        </group>
                        <group string="Dismantling Info">
                            <field name="dismantling_date"/>
                            <field name="technician_id"/>
                            <field name="unbuild_id" readonly="1"
                                   invisible="not unbuild_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dismantling Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="part_name_id" readonly="1"/>
                                    <field name="part_category_id" readonly="1"/>
                                    <field name="assessed_origin_id" readonly="1"/>
                                    <field name="assessed_condition_id" readonly="1"/>
                                    <field name="assessed_qty" readonly="1"/>
                                    <field name="actual_origin_id"/>
                                    <field name="actual_condition_id"/>
                                    <field name="actual_qty"/>
                                    <field name="product_id" readonly="1" optional="hide"/>
                                    <field name="actual_product_id" readonly="1" optional="hide"/>
                                    <field name="lot_id" readonly="1" optional="hide"/>
                                    <field name="cost_weight" readonly="1" optional="hide"/>
                                    <field name="is_included"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Dismantling Search View -->
    <record id="itx_revival_dismantling_view_search" model="ir.ui.view">
        <field name="name">itx.revival.dismantling.view.search</field>
        <field name="model">itx.revival.dismantling</field>
        <field name="arch" type="xml">
            <search string="Search Dismantling Orders">
                <field name="name"/>
                <field name="vin"/>
                <field name="acquired_id"/>
                <field name="spec_id"/>
                <field name="technician_id"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="filter_in_progress"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="filter_done"
                        domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="State" name="groupby_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Technician" name="groupby_technician" domain="[]" context="{'group_by': 'technician_id'}"/>
                    <filter string="Date" name="groupby_date" domain="[]" context="{'group_by': 'dismantling_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Dismantling Action -->
    <record id="itx_revival_dismantling_action" model="ir.actions.act_window">
        <field name="name">Dismantling Orders</field>
        <field name="res_model">itx.revival.dismantling</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No dismantling orders yet
            </p>
            <p>
                สร้าง Dismantling Order จาก Acquired Vehicle ที่ตัดสินใจแตก Part
            </p>
        </field>
    </record>

</odoo>
