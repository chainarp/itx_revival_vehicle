<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extend BOM Form: show itx fields -->
    <record id="mrp_bom_form_inherit_revival" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.revival</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <!-- Add spec field after product_qty in header -->
            <xpath expr="//group//field[@name='product_qty']" position="after">
                <field name="itx_spec_id" readonly="1"
                       invisible="not itx_spec_id"/>
            </xpath>
            <!-- Add itx fields after product_qty in BOM line list -->
            <xpath expr="//field[@name='bom_line_ids']//list//field[@name='product_qty']" position="after">
                <field name="itx_cost_weight" optional="show"/>
                <field name="itx_expected_price" optional="show"/>
                <field name="itx_allocated_cost" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
