<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acquired List View -->
    <record id="itx_revival_acquired_view_list" model="ir.ui.view">
        <field name="name">itx.revival.acquired.view.list</field>
        <field name="model">itx.revival.acquired</field>
        <field name="arch" type="xml">
            <list string="Acquired Vehicles"
                  decoration-info="state == 'draft'"
                  decoration-warning="state in ('po_created', 'releasing', 'stocked', 'dismantling')"
                  decoration-success="state in ('parts_ready', 'delivered', 'closed')"
                  decoration-muted="state == 'settling'">
                <field name="name"/>
                <field name="assessment_id"/>
                <field name="vin"/>
                <field name="spec_id"/>
                <field name="brand_id" optional="hide"/>
                <field name="body_type_id"/>
                <field name="vehicle_year" optional="show"/>
                <field name="purchase_price"/>
                <field name="total_cost"/>
                <field name="expected_revenue"/>
                <field name="actual_revenue" optional="show"/>
                <field name="actual_roi" widget="percentage" optional="hide"/>
                <field name="decision"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('po_created', 'releasing', 'stocked', 'dismantling')"
                       decoration-success="state in ('parts_ready', 'delivered', 'closed')"/>
            </list>
        </field>
    </record>

    <!-- Acquired Form View -->
    <record id="itx_revival_acquired_view_form" model="ir.ui.view">
        <field name="name">itx.revival.acquired.view.form</field>
        <field name="model">itx.revival.acquired</field>
        <field name="arch" type="xml">
            <form string="Acquired Vehicle">
                <header>
                    <!-- draft → po_created (Path B: dismantle — PO ตรง) -->
                    <button name="action_create_po" type="object"
                            string="Create PO (ซื้อแยกซาก)" class="oe_highlight"
                            invisible="state != 'draft' or decision != 'dismantle' or purchase_order_id"/>
                    <!-- draft → po_created (Path A: sell_whole — SO + dropship) -->
                    <button name="action_create_so_dropship" type="object"
                            string="Create SO + Dropship (ขายยกคัน)" class="oe_highlight"
                            invisible="state != 'draft' or decision != 'sell_whole' or sale_order_id"/>
                    <!-- po_created → releasing -->
                    <button name="action_request_release" type="object"
                            string="Request Release (ขอใบปล่อย)" class="oe_highlight"
                            invisible="state != 'po_created'"/>
                    <!-- releasing → stocked (Path B) -->
                    <button name="action_confirm_stock" type="object"
                            string="Confirm Stock (รับรถเข้าโกดัง)" class="oe_highlight"
                            invisible="state != 'releasing' or decision != 'dismantle'"/>
                    <!-- releasing → delivered (Path A) -->
                    <button name="action_delivered" type="object"
                            string="Delivered (ลูกค้ารับรถ)" class="oe_highlight"
                            invisible="state != 'releasing' or decision != 'sell_whole'"/>
                    <!-- stocked → dismantling -->
                    <button name="action_create_dismantling" type="object"
                            string="Start Dismantling" class="oe_highlight"
                            invisible="state != 'stocked' or dismantling_id"/>
                    <!-- parts_ready / delivered → settling -->
                    <button name="action_settle" type="object"
                            string="Settle (ชำระค่าซาก)" class="oe_highlight"
                            invisible="state not in ('parts_ready', 'delivered')"/>
                    <!-- create expense bill -->
                    <button name="action_create_expense_bill" type="object"
                            string="Create Expense Bill (ค่าใช้จ่ายเพิ่ม)"
                            invisible="state in ('draft', 'closed') or expense_bill_id"/>
                    <!-- settling → closed -->
                    <button name="action_close" type="object"
                            string="Close" class="oe_highlight"
                            invisible="state != 'settling'"/>
                    <!-- reset to draft -->
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state == 'draft'"
                            confirm="Reset กลับ Draft? (ข้อมูลที่กรอกไว้จะไม่หาย)"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,po_created,releasing,stocked,dismantling,parts_ready,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- Documents created by Acquired -->
                        <button name="action_view_po" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="not purchase_order_id">
                            <span class="o_stat_text">Purchase Order</span>
                        </button>
                        <button name="action_view_receipt" type="object"
                                class="oe_stat_button" icon="fa-truck"
                                invisible="receipt_count == 0">
                            <field name="receipt_count" widget="statinfo" string="Receipt"/>
                        </button>
                        <button name="action_view_vendor_bill" type="object"
                                class="oe_stat_button" icon="fa-money"
                                invisible="vendor_bill_count == 0">
                            <field name="vendor_bill_count" widget="statinfo" string="Vendor Bill"/>
                        </button>
                        <button name="action_view_expense_bill" type="object"
                                class="oe_stat_button" icon="fa-credit-card"
                                invisible="not expense_bill_id">
                            <span class="o_stat_text">Expense Bill</span>
                        </button>
                        <button name="action_view_dismantling" type="object"
                                class="oe_stat_button" icon="fa-wrench"
                                invisible="not dismantling_id">
                            <span class="o_stat_text">Dismantling</span>
                        </button>
                        <button name="action_view_so" type="object"
                                class="oe_stat_button" icon="fa-shopping-bag"
                                invisible="not sale_order_id">
                            <span class="o_stat_text">Sale Order</span>
                        </button>
                        <button name="action_view_customer_invoice" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="customer_invoice_count == 0">
                            <field name="customer_invoice_count" widget="statinfo" string="Invoice"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Row 1: Source + Vehicle -->
                    <group>
                        <group string="Source">
                            <field name="assessment_id" readonly="1"/>
                            <field name="decision" readonly="1"/>
                            <field name="customer_id"
                                   invisible="decision != 'sell_whole'"/>
                        </group>
                        <group string="Vehicle">
                            <field name="spec_id" readonly="1"/>
                            <field name="body_type_id" readonly="1"/>
                            <field name="vin"/>
                            <field name="vehicle_year"/>
                            <field name="vehicle_color"/>
                            <field name="vehicle_mileage"/>
                        </group>
                    </group>

                    <!-- Row 2: Purchase + Costs -->
                    <group>
                        <group string="Purchase">
                            <field name="vendor_id"/>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="purchase_price"/>
                            <field name="purchase_date"/>
                        </group>
                        <group string="Costs">
                            <field name="transport_cost"/>
                            <field name="dismantling_cost"/>
                            <field name="other_cost"/>
                            <field name="total_cost" readonly="1"/>
                        </group>
                    </group>

                    <!-- Row 3: Release + Settlement -->
                    <group string="Release &amp; Settlement"
                           invisible="state == 'draft'">
                        <group string="Release Document (ใบปล่อยรถ)">
                            <field name="release_request_date" readonly="1"/>
                            <field name="release_doc_date"/>
                            <field name="release_note"/>
                        </group>
                        <group string="Settlement (ชำระค่าซาก)">
                            <field name="company_currency_id" invisible="1"/>
                            <field name="registration_book_received_date"/>
                            <field name="ownership_transfer_status"/>
                            <field name="ownership_transfer_date"
                                   invisible="ownership_transfer_status not in ('in_progress', 'completed')"/>
                        </group>
                    </group>

                    <!-- Row 4: Path A delivery (sell_whole only) -->
                    <group string="Delivery (ขายยกคัน)"
                           invisible="decision != 'sell_whole'">
                        <group>
                            <field name="sale_order_id" readonly="1"/>
                            <field name="delivery_date"/>
                        </group>
                    </group>

                    <!-- Row 5: ROI + Integration -->
                    <group>
                        <group string="ROI Analysis">
                            <field name="expected_revenue" readonly="1"/>
                            <field name="actual_revenue" readonly="1"/>
                            <field name="actual_profit" readonly="1"/>
                            <field name="actual_roi" readonly="1" widget="percentage"/>
                            <field name="sold_percentage" readonly="1" widget="percentage"/>
                        </group>
                        <group string="Integration">
                            <field name="analytic_account_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- Notebook -->
                    <notebook>
                        <page string="Images" name="images">
                            <field name="image_ids">
                                <kanban>
                                    <field name="image"/>
                                    <field name="description"/>
                                    <field name="sequence"/>
                                    <templates>
                                        <t t-name="card">
                                            <field name="image" widget="image" class="o_attachment_image"/>
                                            <span><field name="description"/></span>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Acquired Search View -->
    <record id="itx_revival_acquired_view_search" model="ir.ui.view">
        <field name="name">itx.revival.acquired.view.search</field>
        <field name="model">itx.revival.acquired</field>
        <field name="arch" type="xml">
            <search string="Search Acquired Vehicles">
                <field name="name"/>
                <field name="vin"/>
                <field name="assessment_id"/>
                <field name="spec_id"/>
                <field name="brand_id"/>
                <field name="vendor_id"/>
                <separator/>
                <filter string="Draft" name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="PO Created" name="filter_po"
                        domain="[('state', '=', 'po_created')]"/>
                <filter string="Releasing" name="filter_releasing"
                        domain="[('state', '=', 'releasing')]"/>
                <filter string="In Stock" name="filter_stocked"
                        domain="[('state', '=', 'stocked')]"/>
                <filter string="Dismantling" name="filter_dismantling"
                        domain="[('state', '=', 'dismantling')]"/>
                <filter string="Parts Ready" name="filter_parts_ready"
                        domain="[('state', '=', 'parts_ready')]"/>
                <filter string="Delivered" name="filter_delivered"
                        domain="[('state', '=', 'delivered')]"/>
                <filter string="Settling" name="filter_settling"
                        domain="[('state', '=', 'settling')]"/>
                <filter string="Closed" name="filter_closed"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="To Dismantle" name="filter_dismantle"
                        domain="[('decision', '=', 'dismantle')]"/>
                <filter string="Sell Whole" name="filter_sell_whole"
                        domain="[('decision', '=', 'sell_whole')]"/>
                <separator/>
                <filter string="Active (ยังไม่ปิด)" name="filter_active_flow"
                        domain="[('state', 'not in', ['closed'])]"/>
                <filter string="Archived" name="filter_archived"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter string="State" name="groupby_state" domain="[]" context="{'group_by': 'state'}"/>
                    <filter string="Decision" name="groupby_decision" domain="[]" context="{'group_by': 'decision'}"/>
                    <filter string="Brand" name="groupby_brand" domain="[]" context="{'group_by': 'brand_id'}"/>
                    <filter string="Body Type" name="groupby_body_type" domain="[]" context="{'group_by': 'body_type_id'}"/>
                    <filter string="Vendor" name="groupby_vendor" domain="[]" context="{'group_by': 'vendor_id'}"/>
                    <filter string="Purchase Date" name="groupby_date" domain="[]" context="{'group_by': 'purchase_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acquired Action -->
    <record id="itx_revival_acquired_action" model="ir.actions.act_window">
        <field name="name">Acquired Vehicles</field>
        <field name="res_model">itx.revival.acquired</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No acquired vehicles yet
            </p>
            <p>
                สร้าง Acquired Vehicle จาก Assessment ที่ตัดสินใจซื้อ
            </p>
        </field>
    </record>

</odoo>
